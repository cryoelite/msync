## Global gitignores
./**/.env*
./**/.idea/
design_philosophy.md

## Msync-server
# will have compiled files and executables
msync-server/debug
msync-server/target

# These are backup files generated by rustfmt
msync-server/**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
msync-server/*.pdb

# Generated by cargo mutants
# Contains mutation testing data
msync-server/**/mutants.out*/

msync-server/design_philosophy.md

## Msync-client
# will have compiled files and executables
msync-client/debug
msync-client/target

# These are backup files generated by rustfmt
msync-client/**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
msync-client/*.pdb

# Generated by cargo mutants
# Contains mutation testing data
msync-client/**/mutants.out*/

## MSync-ui

# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
msync-ui/node_modules
msync-ui/.pnp
msync-ui/.pnp.*
msync-ui/.yarn/*
msync-ui/!.yarn/patches
msync-ui/!.yarn/plugins
msync-ui/!.yarn/releases
msync-ui/!.yarn/versions

# testing
msync-ui/coverage

# next.js
msync-ui/.next/
msync-ui/out/

# production
msync-ui/build

# misc
msync-ui/.DS_Store
msync-ui/*.pem

# debug
msync-ui/npm-debug.log*
msync-ui/yarn-debug.log*
msync-ui/yarn-error.log*
msync-ui/.pnpm-debug.log*



# vercel
msync-ui/.vercel

# typescript
msync-ui/*.tsbuildinfo
msync-ui/next-env.d.ts

msync-ui/Guide.md